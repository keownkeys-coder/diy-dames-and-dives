---
import Navigation from '../components/Navigation.astro';
import '../styles/style.css';
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle ="About Me";
const identity = {
    firstName: "Linette",
    country: "The United States",
    occupation: "musician aka jobless and homeless lmao",
    hobbies: ["animation","music","teaching","learning","drawing","watching movies","watching tv showes","frienship makin:)"],
};
const skills = ["HTML","CSS","Google Sheets like hella",];

const finished = true;
const happy = true;
const goal = 7;

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
