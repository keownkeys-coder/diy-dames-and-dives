//https://github.com/keownkeys-coder/diy-dames-and-dives
//https://diy-dames-and-dives.netlify.app/
---
<BaseLayout {pageTitle}>
    

<h1>hello!</h1>
<p><a href="https://keown.bandcamp.com/follow_me">click this shit!</a> 
</p>
<p>if youre wanning to lurn some mores about me HERE YA HO!!</p>
<ul>
    <li>my name is {identity.firstName}</li>
    <li>as unfortunate as it is for the state of the world i do live in {identity.country} while also being a {identity.occupation}</li>
    {identity.hobbies.length >= 2 &&
    <li>Two of my hobbies are: {identity.hobbies[0]} and {identity.hobbies[1]}</li>
  }
</ul>
<p>My skills are:</p>
<ul>
  {skills.map((skill) => <li>{skill}</li>)}
</ul>
{happy && <p>im not dead yet!</p>}
{finished && <p>IM DONE!!! BICH!!! TUTROAILA LALALA COMPLETE</p>}
{goal === 7? <p>my goal is to finish the tutorial in a week</p> : <p>my goal is not 7 days</p>}
</>
